<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RésuméKlinik — Nigeria's Premier Career Clinic</title>
<meta name="description" content="Premium CV writing, LinkedIn optimisation, and career strategy for ambitious African professionals. ATS-optimised. Expert-reviewed. Results guaranteed.">
<meta property="og:title" content="RésuméKlinik — Empowering Careers, Connecting Opportunities">
<meta property="og:description" content="Nigeria's most trusted career clinic. 500+ CVs transformed. Big 4 placements secured.">
<meta property="og:url" content="https://resumeklinik.com">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,300;1,9..144,700&family=Cabinet+Grotesk:wght@300;400;500;700;800&display=swap" rel="stylesheet">
<style>
/* ─── TOKENS ──────────────────────────────────────────────── */
:root{
  --lime:#8DC63F; --lime2:#A8D84E; --lime3:#C5E87A; --limedark:#6BA528;
  --navy:#1C2E4A; --navy2:#243856; --navy3:#0D1825;
  --cream:#F5F8EF; --cream2:#EAF0DC; --off:#FAFAF7;
  --text:#0D1825; --muted:#5A6E7F; --faint:#9EB3C4;
  --bd:rgba(28,46,74,0.09); --bdhov:rgba(141,198,63,0.35);
  --r:14px; --rs:9px;
  --shadow: 0 4px 28px rgba(28,46,74,0.09);
  --shadowlg: 0 16px 56px rgba(28,46,74,0.14);
}

/* ─── RESET ───────────────────────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px;overflow-x:hidden}
body{font-family:'Cabinet Grotesk',sans-serif;background:var(--off);color:var(--text);-webkit-font-smoothing:antialiased;overflow-x:hidden;cursor:none}
img{max-width:100%;display:block}
a{text-decoration:none;color:inherit}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:var(--lime);border-radius:2px}

/* ─── CUSTOM CURSOR ───────────────────────────────────────── */
.cursor{position:fixed;pointer-events:none;z-index:9999;mix-blend-mode:multiply}
.cursor-dot{width:8px;height:8px;background:var(--lime);border-radius:50%;transform:translate(-50%,-50%);transition:transform .1s}
.cursor-ring{width:36px;height:36px;border:1.5px solid var(--navy);border-radius:50%;transform:translate(-50%,-50%);transition:all .15s ease;opacity:.5}
.cursor-ring.hov{width:56px;height:56px;border-color:var(--lime);opacity:.8;border-width:2px}

/* ─── TYPOGRAPHY ──────────────────────────────────────────── */
h1,h2,h3,.serif{font-family:'Fraunces',serif}
.eyebrow{font-size:10.5px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--limedark)}
.eyebrow-w{color:var(--lime3)}

/* ─── LAYOUT ──────────────────────────────────────────────── */
.wrap{width:90%;max-width:1160px;margin:0 auto}
section{padding:96px 0}

/* ─── NAVIGATION ──────────────────────────────────────────── */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;transition:all .3s}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:68px}
.nav.scrolled{background:rgba(13,24,37,0.96);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.04)}
.nav-logo{display:flex;align-items:center;gap:10px}
.nav-logo img{height:40px;width:auto;border-radius:7px}
.nav-links{display:flex;align-items:center;gap:4px}
.nl{color:rgba(255,255,255,0.55);font-size:13.5px;font-weight:500;padding:8px 14px;border-radius:8px;transition:all .2s;position:relative}
.nl::after{content:'';position:absolute;bottom:4px;left:14px;right:14px;height:1.5px;background:var(--lime);transform:scaleX(0);transform-origin:left;transition:transform .25s}
.nl:hover{color:rgba(255,255,255,.9)}.nl:hover::after{transform:scaleX(1)}
.nav-ctas{display:flex;align-items:center;gap:8px}
.n-wa{display:flex;align-items:center;gap:7px;background:rgba(37,211,102,0.1);border:1px solid rgba(37,211,102,0.22);color:#25D366;padding:8px 16px;border-radius:22px;font-size:13px;font-weight:600;transition:all .2s}
.n-wa:hover{background:rgba(37,211,102,0.2);transform:translateY(-1px)}
.n-wa svg{width:14px;height:14px;fill:#25D366;flex-shrink:0}
.n-cta{background:var(--lime);color:var(--navy);font-size:13px;font-weight:700;padding:9px 22px;border-radius:22px;transition:all .22s;letter-spacing:.01em}
.n-cta:hover{background:var(--lime3);transform:translateY(-2px);box-shadow:0 6px 24px rgba(141,198,63,0.38)}
.ham{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px}
.ham span{width:22px;height:1.5px;background:rgba(255,255,255,0.7);border-radius:1px;transition:all .3s;display:block}
.mob-nav{display:none;position:fixed;inset:0;background:rgba(13,24,37,0.99);z-index:200;flex-direction:column;align-items:center;justify-content:center;gap:8px}
.mob-nav.open{display:flex}
.mob-close{position:absolute;top:20px;right:20px;background:none;border:none;color:rgba(255,255,255,.5);font-size:28px;cursor:pointer;font-family:'Cabinet Grotesk',sans-serif}
.mob-link{font-family:'Fraunces',serif;font-size:clamp(32px,6vw,52px);font-weight:700;color:rgba(255,255,255,.7);transition:color .2s;padding:6px 0}
.mob-link:hover{color:var(--lime2)}

/* ─── HERO ────────────────────────────────────────────────── */
.hero{min-height:100vh;background:var(--navy3);display:flex;align-items:center;padding-top:68px;position:relative;overflow:hidden}
/* animated mesh background */
.hero-mesh{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.mesh-blob{position:absolute;border-radius:50%;filter:blur(80px);animation:blobFloat 16s ease-in-out infinite}
.mb1{width:900px;height:900px;background:radial-gradient(circle,rgba(141,198,63,.09) 0%,transparent 70%);top:-30%;right:-20%;animation-duration:18s}
.mb2{width:600px;height:600px;background:radial-gradient(circle,rgba(28,46,74,.8) 0%,transparent 70%);bottom:-20%;left:-10%;animation-duration:14s;animation-direction:reverse}
.mb3{width:400px;height:400px;background:radial-gradient(circle,rgba(141,198,63,.05) 0%,transparent 70%);top:40%;left:35%;animation-duration:22s}
@keyframes blobFloat{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(30px,-20px) scale(1.04)}66%{transform:translate(-20px,30px) scale(.96)}}
/* dot grid */
.hero-grid{position:absolute;inset:0;background-image:radial-gradient(circle,rgba(141,198,63,.12) 1px,transparent 1px);background-size:44px 44px;pointer-events:none}
/* running ticker line */
.hero-ticker-line{position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(141,198,63,.3),rgba(141,198,63,.6),rgba(141,198,63,.3),transparent)}

.hero-inner{position:relative;z-index:2;display:grid;grid-template-columns:1fr 460px;gap:64px;align-items:center}

/* left column */
.hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(141,198,63,.09);border:1px solid rgba(141,198,63,.2);border-radius:30px;padding:6px 16px;margin-bottom:24px;animation:tagSlide .8s ease forwards}
@keyframes tagSlide{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.hero-tag-dot{width:7px;height:7px;background:var(--lime);border-radius:50%;box-shadow:0 0 8px var(--lime);animation:tagPulse 2s ease-in-out infinite}
@keyframes tagPulse{0%,100%{opacity:1}50%{opacity:.3}}
.hero-tag p{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--lime3)}

h1.hero-h{font-size:clamp(44px,5.5vw,76px);font-weight:900;color:#fff;line-height:1.04;letter-spacing:-2px;animation:heroTitleIn 1s .1s ease both}
@keyframes heroTitleIn{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
h1.hero-h em{color:var(--lime);font-style:italic}
h1.hero-h .line2{display:block;color:rgba(255,255,255,.35);font-style:italic;font-size:.85em}

.hero-sub{font-size:17px;color:rgba(255,255,255,.46);line-height:1.78;max-width:480px;margin:22px 0 36px;font-weight:300;animation:heroSubIn 1s .25s ease both}
@keyframes heroSubIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:48px;animation:heroBtnsIn 1s .38s ease both}
@keyframes heroBtnsIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:11px;font-size:15px;font-weight:600;cursor:pointer;border:none;font-family:'Cabinet Grotesk',sans-serif;transition:all .22s;letter-spacing:.01em}
.btn-g{background:var(--lime);color:var(--navy)}.btn-g:hover{background:var(--lime3);transform:translateY(-3px);box-shadow:0 8px 32px rgba(141,198,63,.4)}
.btn-o{background:transparent;color:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.14)}.btn-o:hover{border-color:rgba(255,255,255,.38);color:#fff;transform:translateY(-2px)}
.btn-wa{background:rgba(37,211,102,.1);color:#25D366;border:1px solid rgba(37,211,102,.24)}.btn-wa:hover{background:rgba(37,211,102,.18);transform:translateY(-2px)}
.btn-wa svg{width:17px;height:17px;fill:#25D366}

.hero-trust{display:flex;align-items:center;gap:22px;animation:heroTrustIn 1s .5s ease both}
@keyframes heroTrustIn{from{opacity:0}to{opacity:1}}
.trust-stat{text-align:center}
.trust-n{font-family:'Fraunces',serif;font-size:28px;font-weight:700;color:var(--lime);line-height:1}
.trust-l{font-size:11px;color:rgba(255,255,255,.3);margin-top:4px;text-transform:uppercase;letter-spacing:.06em}
.trust-div{width:1px;height:36px;background:rgba(255,255,255,.08)}

/* right column – stacked cards */
.hero-cards{position:relative;height:520px}
.hc{position:absolute;background:rgba(255,255,255,.04);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:20px}

.hc-main{width:320px;top:0;right:0;animation:cardFloat1 6s ease-in-out infinite}
@keyframes cardFloat1{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.hc-main-top{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.06)}
.hc-logo{height:34px;width:auto;max-width:140px;border-radius:6px}
.hc-label{font-size:12px;color:rgba(255,255,255,.35);font-style:italic}
.hc-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)}
.hc-row:last-child{border:none}
.hc-dot{width:6px;height:6px;border-radius:50%;background:var(--lime);flex-shrink:0}
.hc-txt{font-size:13px;color:rgba(255,255,255,.6);font-weight:400}
.hc-tag{margin-left:auto;font-size:9.5px;font-weight:700;padding:2px 8px;border-radius:10px;background:rgba(141,198,63,.12);color:var(--lime);letter-spacing:.04em}
.hc-foot{padding-top:14px;margin-top:4px}
.hc-foot a{display:flex;align-items:center;justify-content:center;background:var(--lime);color:var(--navy);border-radius:8px;padding:11px;font-size:13.5px;font-weight:700;transition:all .2s;gap:6px}
.hc-foot a:hover{background:var(--lime3)}

/* floating mini-cards */
.hc-score{width:200px;bottom:20px;left:0;padding:16px;animation:cardFloat2 7s 1s ease-in-out infinite}
@keyframes cardFloat2{0%,100%{transform:translateY(0)}50%{transform:translateY(8px)}}
.hcs-label{font-size:11px;color:rgba(255,255,255,.38);margin-bottom:8px;font-weight:500}
.hcs-num{font-family:'Fraunces',serif;font-size:38px;font-weight:900;color:var(--lime);line-height:1;margin-bottom:2px}
.hcs-sub{font-size:11px;color:rgba(255,255,255,.28)}
.hcs-bar{height:4px;background:rgba(255,255,255,.07);border-radius:2px;margin-top:10px;overflow:hidden}
.hcs-fill{height:100%;width:78%;background:linear-gradient(90deg,var(--lime),var(--lime3));border-radius:2px;animation:fillGrow 1.2s 1s ease both}
@keyframes fillGrow{from{width:0}to{width:78%}}

.hc-ats{width:160px;top:180px;left:-20px;padding:14px;animation:cardFloat3 8s 2s ease-in-out infinite}
@keyframes cardFloat3{0%,100%{transform:translateY(0) rotate(-1deg)}50%{transform:translateY(-8px) rotate(0deg)}}
.ats-check{width:28px;height:28px;background:rgba(141,198,63,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.ats-check svg{width:14px;height:14px;stroke:var(--lime);fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.ats-t{font-size:12px;font-weight:700;color:#fff;margin-bottom:2px}
.ats-s{font-size:10.5px;color:rgba(255,255,255,.35)}

/* ─── MARQUEE / TICKER ────────────────────────────────────── */
.ticker{background:var(--lime);padding:14px 0;overflow:hidden;white-space:nowrap}
.ticker-track{display:inline-flex;gap:0;animation:tickerScroll 24s linear infinite}
.ticker-track:hover{animation-play-state:paused}
.ticker-item{display:inline-flex;align-items:center;gap:16px;padding:0 28px;font-size:13px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:.08em}
.ticker-sep{width:5px;height:5px;background:var(--navy);border-radius:50%;opacity:.3;flex-shrink:0}
@keyframes tickerScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* ─── ABOUT ───────────────────────────────────────────────── */
.about{background:var(--off);overflow:hidden}
.about-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-visual{position:relative}
.about-img-wrap{position:relative;border-radius:20px;overflow:hidden}
.about-img-wrap img{width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top;border-radius:20px;filter:saturate(1.1)}
.about-img-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(13,24,37,.7) 0%,transparent 50%);border-radius:20px}
.about-img-badge{position:absolute;bottom:24px;left:24px;right:24px;background:rgba(255,255,255,.12);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.18);border-radius:14px;padding:16px 18px}
.aib-name{font-family:'Fraunces',serif;font-size:20px;font-weight:700;color:#fff;margin-bottom:2px}
.aib-role{font-size:12px;color:rgba(255,255,255,.55)}
.aib-li{display:inline-flex;align-items:center;gap:7px;background:rgba(10,102,194,.2);border:1px solid rgba(10,102,194,.3);color:#5B9FFF;padding:6px 13px;border-radius:20px;font-size:12px;font-weight:600;margin-top:10px;transition:all .2s}
.aib-li:hover{background:rgba(10,102,194,.35);transform:translateY(-1px)}
.about-floater{position:absolute;top:-20px;right:-20px;background:var(--lime);border-radius:14px;padding:16px 18px;box-shadow:0 8px 32px rgba(141,198,63,.35)}
.af-n{font-family:'Fraunces',serif;font-size:28px;font-weight:900;color:var(--navy);line-height:1}
.af-l{font-size:11px;font-weight:700;color:rgba(28,46,74,.55);text-transform:uppercase;letter-spacing:.06em;margin-top:3px}
.about-text .eyebrow{margin-bottom:10px}
.about-text h2{font-size:clamp(30px,3.5vw,46px);font-weight:700;line-height:1.1;letter-spacing:-.8px;margin-bottom:18px;color:var(--text)}
.about-text h2 em{color:var(--limedark);font-style:italic}
.about-text .lead{font-size:16px;color:var(--muted);line-height:1.85;font-weight:300;margin-bottom:16px}
.blockquote{border-left:3px solid var(--lime);padding:14px 20px;background:var(--cream);border-radius:0 12px 12px 0;margin:22px 0;font-family:'Fraunces',serif;font-size:18px;font-style:italic;color:var(--navy2);line-height:1.6}
.about-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:28px}
.as{background:var(--cream);border:1px solid var(--bd);border-radius:12px;padding:16px;text-align:center;transition:all .2s}
.as:hover{border-color:var(--bdhov);background:var(--cream2);transform:translateY(-2px)}
.as-n{font-family:'Fraunces',serif;font-size:28px;font-weight:900;color:var(--limedark);line-height:1}
.as-l{font-size:11px;color:var(--faint);text-transform:uppercase;letter-spacing:.06em;margin-top:4px}

/* ─── SERVICES ────────────────────────────────────────────── */
.services{background:var(--navy3);overflow:hidden}
.services-head{text-align:center;margin-bottom:60px}
.services-head h2{font-size:clamp(30px,4vw,52px);font-weight:900;color:#fff;letter-spacing:-1px;line-height:1.08}
.services-head h2 em{color:var(--lime);font-style:italic}
.services-head p{font-size:16px;color:rgba(255,255,255,.42);max-width:500px;margin:14px auto 0;font-weight:300;line-height:1.78}
.svcs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.svc{background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:28px;transition:all .28s;position:relative;overflow:hidden;cursor:default}
.svc::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(141,198,63,.04),transparent);opacity:0;transition:opacity .3s;border-radius:18px}
.svc:hover{transform:translateY(-6px);border-color:rgba(141,198,63,.28);box-shadow:0 20px 60px rgba(0,0,0,.3)}
.svc:hover::before{opacity:1}
.svc.featured{background:rgba(141,198,63,.07);border-color:rgba(141,198,63,.22)}
.svc-num{font-family:'Fraunces',serif;font-size:13px;font-weight:700;color:rgba(141,198,63,.4);letter-spacing:.06em;margin-bottom:16px}
.svc-icon{width:48px;height:48px;background:linear-gradient(135deg,var(--lime),var(--limedark));border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;box-shadow:0 4px 18px rgba(107,165,40,.3)}
.svc-icon svg{stroke:#1c2e4a;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.svc-t{font-family:'Fraunces',serif;font-size:20px;font-weight:700;color:#fff;margin-bottom:10px;line-height:1.2}
.svc-d{font-size:13.5px;color:rgba(255,255,255,.44);line-height:1.72;font-weight:300}
.svc-cta{font-size:11.5px;font-weight:700;color:var(--lime3);text-transform:uppercase;letter-spacing:.08em;display:block;margin-top:18px}
.svc.featured .svc-num{color:rgba(141,198,63,.7)}

/* ─── PRICING ─────────────────────────────────────────────── */
.pricing{background:var(--cream);overflow:hidden}
.pricing-head{text-align:center;margin-bottom:56px}
.pricing-head h2{font-size:clamp(28px,3.5vw,48px);font-weight:900;letter-spacing:-1px;color:var(--text)}
.pricing-head h2 em{color:var(--limedark);font-style:italic}
.pricing-head p{font-size:15px;color:var(--muted);max-width:460px;margin:12px auto 0;line-height:1.78;font-weight:300}
.price-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.pc{border-radius:18px;padding:28px;transition:all .25s;position:relative;border:1.5px solid var(--bd)}
.pc.std{background:var(--off)}
.pc.std:hover{transform:translateY(-5px);border-color:var(--bdhov);box-shadow:var(--shadowlg)}
.pc.pop{background:var(--navy3);border-color:rgba(141,198,63,.3)}
.pc-crown{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--lime);color:var(--navy);font-size:10px;font-weight:800;padding:4px 14px;border-radius:20px;white-space:nowrap;letter-spacing:.05em}
.pc-tier{font-size:10px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;margin-bottom:10px}
.pc.std .pc-tier{color:var(--faint)}.pc.pop .pc-tier{color:var(--lime)}
.pc-name{font-family:'Fraunces',serif;font-size:20px;font-weight:700;margin-bottom:6px}
.pc.std .pc-name{color:var(--text)}.pc.pop .pc-name{color:#fff}
.pc-price{font-family:'Fraunces',serif;font-size:27px;font-weight:900;color:var(--limedark);line-height:1;margin-bottom:5px}
.pc.pop .pc-price{color:var(--lime2)}
.pc-exp{font-size:11px;color:var(--faint);margin-bottom:18px}
.pc.pop .pc-exp{color:rgba(255,255,255,.3)}
.pc-div{height:1px;margin-bottom:18px}
.pc.std .pc-div{background:var(--bd)}.pc.pop .pc-div{background:rgba(255,255,255,.07)}
.pc-feats{font-size:13px;line-height:2.2}
.pc.std .pc-feats{color:var(--muted)}.pc.pop .pc-feats{color:rgba(255,255,255,.5)}
.pc-feats li{list-style:none;display:flex;align-items:center;gap:8px}
.pc-feats li::before{content:'';width:6px;height:6px;border-radius:50%;flex-shrink:0}
.pc.std .pc-feats li::before{background:var(--lime)}.pc.pop .pc-feats li::before{background:var(--lime2)}
.pc-btn{display:block;margin-top:22px;padding:11px;border-radius:10px;font-size:13.5px;font-weight:700;text-align:center;transition:all .2s;font-family:'Cabinet Grotesk',sans-serif;cursor:pointer;border:none}
.pc.std .pc-btn{background:var(--cream2);color:var(--navy);border:1.5px solid var(--bd)}
