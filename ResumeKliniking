// ── CUSTOM CURSOR ──────────────────────────────────────────
const dot = document.getElementById('cdot');
const ring = document.getElementById('cring');
let mx = 0, my = 0, rx = 0, ry = 0;
document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; dot.style.left = mx + 'px'; dot.style.top = my + 'px'; });
(function animRing() { rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12; ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; requestAnimationFrame(animRing); })();
document.querySelectorAll('a,button,.svc,.ind,.pc,.as,.hc').forEach(el => {
  el.addEventListener('mouseenter', () => ring.classList.add('hov'));
  el.addEventListener('mouseleave', () => ring.classList.remove('hov'));
});

// ── NAV SCROLL ─────────────────────────────────────────────
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 60);
});

// ── MOBILE MENU ────────────────────────────────────────────
function openMob() { document.getElementById('mobNav').classList.add('open'); document.body.style.overflow = 'hidden'; }
function closeMob() { document.getElementById('mobNav').classList.remove('open'); document.body.style.overflow = ''; }

// ── SCROLL REVEAL ──────────────────────────────────────────
const ro = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('on'); ro.unobserve(e.target); } });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.rv,.rv-l,.rv-r').forEach((el, i) => {
  el.style.transitionDelay = (i % 4) * 80 + 'ms';
  ro.observe(el);
});

// ── FORM ───────────────────────────────────────────────────
document.getElementById('eq-form').addEventListener('submit', function(e) {
  e.preventDefault();
  const d = new FormData(this);
  const n = d.get('name') || '';
  const ph = d.get('phone') || '';
  const sv = d.get('service') || '';
  const ind = d.get('industry') || '';
  const msg = d.get('message') || '';
  const wa = encodeURIComponent('New enquiry from resumeklinik.com:\n\nName: ' + n + '\nPhone: ' + ph + '\nService: ' + sv + '\nIndustry: ' + ind + '\nMessage: ' + msg);
  fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(d).toString() })
    .catch(() => {})
    .finally(() => {
      this.style.display = 'none';
      document.getElementById('form-done').style.display = 'block';
      setTimeout(() => { try { window.open('https://wa.me/2348081688328?text=' + wa, '_blank'); } catch(e) {} }, 500);
    });
});
</script>
